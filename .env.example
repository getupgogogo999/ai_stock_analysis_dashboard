# ══════════════════════════════════════════════════════════════
# ⚠️  安全提示
# 此文件仅为模板，可以安全提交到 GitHub（不含真实密钥）。
# 请复制本文件为 .env 并填入你的真实 API Key：
#   cp .env.example .env        (Mac/Linux)
#   copy .env.example .env      (Windows)
# .env 已被 .gitignore 忽略，绝对不要提交到 Git！
# ══════════════════════════════════════════════════════════════

# Finnhub - free stock market data: https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_api_key

# OpenAI - LLM analysis: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
# 可选：OpenAI 兼容代理地址（仍填在 .env，不提交 GitHub）
# OPENAI_BASE_URL=https://api.openai.com/v1
# 可选：浏览器能访问 OpenAI 但后端超时时，填写本地 VPN/Clash 代理端口
# HTTPS_PROXY=http://127.0.0.1:7890

# Supabase - https://supabase.com/dashboard
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# Server
PORT=3001
NODE_ENV=development

# PyTorch ML service (local FastAPI, default port 8000)
ML_SERVICE_URL=http://127.0.0.1:8000
# 本地开发时后端会自动拉起 ML 服务；设为 false 可关闭
# ML_AUTO_START=false
